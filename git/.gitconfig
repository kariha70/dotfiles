[user]
	name = Kari Hagemeier
	email = kari@hagemeier.cloud

[include]
	path = ~/.gitconfig.local

[core]
	editor = vim
	excludesfile = ~/.gitignore_global
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	light = false
	side-by-side = true
	line-numbers = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default

[color]
	ui = auto

[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
[init]
	defaultBranch = main
[credential]
	helper = /mnt/c/Program Files/Git/mingw64/bin/git-credential-manager.exe
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
